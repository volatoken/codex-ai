# ==========================================
# Codex AI — Rust Gateway + DeerFlow Backend
# Copy to .env and fill in your values
# ==========================================

# === Telegram (REQUIRED) ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_ID=-100xxxxxxxxxx
TELEGRAM_ADMIN_USER_ID=your_user_id_here

# === LLM (REQUIRED) ===
# Used by DeerFlow for all AI/LLM calls
LLM_PROVIDER=openrouter
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4
LLM_MODEL_FAST=anthropic/claude-haiku-4

# === DeerFlow Backend ===
# URL where DeerFlow LangGraph server is running
DEERFLOW_URL=http://localhost:2024

# === Search (Optional — for DeerFlow research) ===
TAVILY_API_KEY=
SEARCH_API=tavily

# === Memory (Optional) ===
MEM0_API_KEY=
QDRANT_URL=http://localhost:6333

# === VPS Resources ===
TOTAL_RAM_MB=8192
